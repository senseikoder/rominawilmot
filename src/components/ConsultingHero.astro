---
import ConsultingImage from '../assets/consulting-bg-boston.webp';
---
<section class="relative h-[719px] flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img alt="City Skyline" class="w-full h-full object-cover grayscale-[20%] brightness-[40%]" src={ConsultingImage.src}>
    <div class="absolute inset-0 bg-gradient-to-br from-primary/60 to-transparent"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
    <div class="max-w-2xl">
      <h1 class="font-headline text-display-lg text-white text-6xl font-extrabold tracking-tighter my-6 leading-tight">
        RW Consulting
      </h1>
      <p class="text-white text-2xl font-body leading-relaxed opacity-90 mb-8 border-l-4 border-secondary pl-6">
        Connect more meaningfully with your patients, clients, and hard to reach populations to get them the healthcare and resources they need.
      </p>
      <div class="flex gap-4">
        <button class="bg-secondary text-white px-8 py-4 rounded-lg font-bold transition-transform hover:scale-105">
          Learn More
        </button>
      </div>
    </div>
  </div>
</section>