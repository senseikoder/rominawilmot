---
import logo from '../assets/logo_romina_wilmot.webp';
---
<nav class="absolute top-4 left-1/2 -translate-x-1/2 w-[95%] max-w-7xl rounded-full bg-white/85 backdrop-blur-xs shadow-xl shadow-primary/5 flex justify-between items-center px-8 py-4 z-50 transition-all border border-slate-100">
  <a href="/" class="w-24 ml-8">
    <img src={logo.src} alt="RW Consulting" class="w-full h-auto" />
  </a>
  <div class="hidden md:flex items-center gap-8">
    <a class="text-primary border-b-2 border-secondary pb-1 font-headline tracking-tight font-bold text-md" href="/">Home</a>
    <a class="text-slate-500 hover:text-primary font-headline tracking-tight font-bold text-md transition-colors" href="/consulting">Consulting</a>
    <a class="text-slate-500 hover:text-primary font-headline tracking-tight font-bold text-md transition-colors" href="/about">About</a>
  </div>
  <button class="bg-primary text-white px-6 py-2 rounded-full font-bold text-md transition-all duration-300 hover:bg-primary/90">
    Contact Us
  </button>
</nav>